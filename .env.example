# =============================================================================
# Copier ce fichier en .env et renseigner les valeurs réelles.
# Ne jamais committer le fichier .env dans le dépôt Git.
# =============================================================================

# Secret JWT encodé en Base64 (min. 32 octets aléatoires)
# Générer avec : openssl rand -base64 32
JWT_SECRET=

# Clé API Google Maps
GOOGLE_MAPS_API_KEY=

# Base de données
DB_URL=jdbc:mysql://localhost:3306/badier_ride?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=
DB_PASSWORD=
